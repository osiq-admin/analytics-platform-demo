{
  "semantic_id": "business_metrics",
  "version": "1.0",
  "description": "Business-friendly metric definitions for trade surveillance semantic layer",
  "metrics": [
    {
      "metric_id": "daily_alert_rate",
      "business_name": "Daily Alert Rate",
      "definition": "Number of surveillance alerts generated per trading day, normalized by total trade count.",
      "formula": "COUNT(alerts WHERE date = :date) / COUNT(executions WHERE execution_date = :date)",
      "source_tier": "platinum",
      "source_entities": ["execution"],
      "unit": "ratio",
      "format": "percentage",
      "dimensions": ["business_date", "model", "asset_class"],
      "owner": "surveillance_team",
      "glossary_term_id": "alert_score",
      "bcbs239_principle": "timeliness"
    },
    {
      "metric_id": "wash_trade_rate",
      "business_name": "Wash Trade Detection Rate",
      "definition": "Percentage of executions flagged as potential wash trades relative to total execution volume.",
      "formula": "COUNT(executions WHERE wash_score > threshold) / COUNT(executions)",
      "source_tier": "gold",
      "source_entities": ["execution"],
      "unit": "ratio",
      "format": "percentage",
      "dimensions": ["business_date", "asset_class", "trader"],
      "owner": "surveillance_team",
      "glossary_term_id": "wash_trade",
      "bcbs239_principle": "accuracy"
    },
    {
      "metric_id": "spoofing_detection_rate",
      "business_name": "Spoofing Detection Rate",
      "definition": "Percentage of orders flagged as potential spoofing relative to total order volume.",
      "formula": "COUNT(orders WHERE spoof_score > threshold) / COUNT(orders)",
      "source_tier": "gold",
      "source_entities": ["order"],
      "unit": "ratio",
      "format": "percentage",
      "dimensions": ["business_date", "asset_class", "venue"],
      "owner": "surveillance_team",
      "glossary_term_id": "spoofing",
      "bcbs239_principle": "accuracy"
    },
    {
      "metric_id": "model_effectiveness_ratio",
      "business_name": "Model Effectiveness Ratio",
      "definition": "True positive rate of a detection model — proportion of generated alerts that are confirmed as genuine suspicious activity.",
      "formula": "COUNT(alerts WHERE outcome = 'confirmed') / COUNT(alerts WHERE outcome IN ('confirmed', 'false_positive'))",
      "source_tier": "platinum",
      "source_entities": ["execution"],
      "unit": "ratio",
      "format": "percentage",
      "dimensions": ["model", "business_date"],
      "owner": "surveillance_team",
      "glossary_term_id": "alert_score",
      "bcbs239_principle": "accuracy"
    },
    {
      "metric_id": "alert_score_distribution",
      "business_name": "Alert Score Distribution",
      "definition": "Statistical distribution of alert scores across all active alerts, showing concentration at different confidence levels.",
      "formula": "HISTOGRAM(alert_score, bins=[0,20,40,60,80,100])",
      "source_tier": "platinum",
      "source_entities": ["execution"],
      "unit": "score",
      "format": "histogram",
      "dimensions": ["model", "asset_class"],
      "owner": "surveillance_team",
      "glossary_term_id": "alert_score",
      "bcbs239_principle": "completeness"
    },
    {
      "metric_id": "overall_quality_score",
      "business_name": "Overall Data Quality Score",
      "definition": "Weighted composite score of completeness, accuracy, timeliness, and uniqueness quality dimensions.",
      "formula": "SUM(dimension_score * dimension_weight) / SUM(dimension_weight)",
      "source_tier": "gold",
      "source_entities": ["product", "execution", "order"],
      "unit": "score",
      "format": "decimal",
      "dimensions": ["business_date"],
      "owner": "data_quality_team",
      "glossary_term_id": "data_accuracy",
      "bcbs239_principle": "accuracy"
    },
    {
      "metric_id": "completeness_ratio",
      "business_name": "Field Completeness Ratio",
      "definition": "Proportion of non-null required fields across all records in an entity.",
      "formula": "COUNT(non_null_required_fields) / COUNT(total_required_fields)",
      "source_tier": "silver",
      "source_entities": ["product", "execution", "order", "account", "trader"],
      "unit": "ratio",
      "format": "percentage",
      "dimensions": ["asset_class", "product_type"],
      "owner": "data_quality_team",
      "glossary_term_id": "data_completeness",
      "bcbs239_principle": "completeness"
    },
    {
      "metric_id": "timeliness_sla_compliance",
      "business_name": "Timeliness SLA Compliance",
      "definition": "Percentage of data records arriving within the defined SLA window after the originating event.",
      "formula": "COUNT(records WHERE arrival_time - event_time <= sla_threshold) / COUNT(records)",
      "source_tier": "silver",
      "source_entities": ["execution", "md_intraday"],
      "unit": "ratio",
      "format": "percentage",
      "dimensions": ["business_date"],
      "owner": "data_quality_team",
      "glossary_term_id": "data_timeliness",
      "bcbs239_principle": "timeliness"
    },
    {
      "metric_id": "daily_trading_volume",
      "business_name": "Daily Trading Volume",
      "definition": "Total execution quantity across all instruments for a given trading day.",
      "formula": "SUM(execution.quantity WHERE execution_date = :date)",
      "source_tier": "gold",
      "source_entities": ["execution"],
      "unit": "quantity",
      "format": "integer",
      "dimensions": ["business_date", "asset_class", "venue"],
      "owner": "trading_ops",
      "glossary_term_id": "trade_execution",
      "bcbs239_principle": "completeness"
    },
    {
      "metric_id": "cross_asset_concentration",
      "business_name": "Cross-Asset Concentration Index",
      "definition": "Herfindahl-Hirschman Index measuring the concentration of trading volume across asset classes.",
      "formula": "SUM((asset_class_volume / total_volume) ^ 2) * 10000",
      "source_tier": "gold",
      "source_entities": ["execution", "product"],
      "unit": "index",
      "format": "decimal",
      "dimensions": ["business_date", "trader", "account"],
      "owner": "surveillance_team",
      "glossary_term_id": "concentration_ratio",
      "bcbs239_principle": "accuracy"
    },
    {
      "metric_id": "golden_record_coverage",
      "business_name": "Golden Record Coverage",
      "definition": "Percentage of entity records that have been matched to and enriched by a golden reference record.",
      "formula": "COUNT(entities WITH golden_record) / COUNT(entities)",
      "source_tier": "gold",
      "source_entities": ["product", "venue", "account", "trader"],
      "unit": "ratio",
      "format": "percentage",
      "dimensions": ["asset_class"],
      "owner": "data_management",
      "glossary_term_id": "data_accuracy",
      "bcbs239_principle": "completeness"
    },
    {
      "metric_id": "insider_dealing_indicator",
      "business_name": "Insider Dealing Composite Indicator",
      "definition": "Composite score combining price movement correlation with trade timing proximity to material events.",
      "formula": "CORR(trade_timing, event_timing) * ABS(price_movement) * volume_factor",
      "source_tier": "platinum",
      "source_entities": ["execution", "md_eod"],
      "unit": "score",
      "format": "decimal",
      "dimensions": ["business_date", "trader", "product_type"],
      "owner": "surveillance_team",
      "glossary_term_id": "insider_dealing",
      "bcbs239_principle": "accuracy"
    }
  ]
}
